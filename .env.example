# Claude Code (Anthropic API key for headless execution)
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# DeepSeek (for cheap task planning/summarization)
DEEPSEEK_API_KEY=sk-your-deepseek-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Telegram Bot
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
TELEGRAM_CHAT_ID=your-chat-id-here

# Optional: Override Claude Code model
CLAUDE_MODEL=sonnet

# Optional: Default project directory
DEFAULT_REPO_PATH=/Users/wilson/projects

# Optional: Budget defaults (can also be set per-project in YAML)
DEFAULT_TASK_BUDGET=5.0
DEFAULT_PROJECT_BUDGET=75.0
DEFAULT_HOURLY_BUDGET=15.0
